graph TD
    subgraph Cliente ["CLIENTE"]
        direction TB
        Start((Inicio)) -->|Pedido| SolicitaPedido[Solicita Mercadería]
        RecibeProd[Recibe Mercadería]
        RecibeProd --> DecidePago{Forma de Pago}
        DecidePago -->|Tarjeta| PagaTarjeta[Presenta Tarjeta]
        DecidePago -->|Efectivo| PagaEfectivo[Entrega Efectivo]
        Start((Devolución)) -->|Mercadería a devolver| SolicitaDevolucion[Solicita Devolución]
        SolicitaDevolucion --> DecideDevolucion{Devolución}
        DecideDevolucion -->|Tarjeta| DevolTarjeta[Devolución Tarjeta]
        DecideDevolucion -->|Efectivo| DevolEfectivo[Devolución Efectivo]
    end

    subgraph Vendedor ["VENDEDOR"]
        direction TB
        SolicitaPedido -->|Pedido| CargaApp[Carga pedido]
        CargaApp -->|Almacén| EntregaFisica[Entrega Física]
        EntregaFisica --> RecibeProd

        %% Lógica de Cobro según medio
        PagaTarjeta -->|Procesar| TPV_Bank[TPV: Conexión Banco]
        PagaEfectivo -->|Cobrar| TPV_Caja[TPV: Apertura Cajón]
        
        TPV_Bank --> EmiteTick[Emisión de Ticket]
        TPV_Caja --> EmiteTick
        EmiteTick --> End((Fin))

        DevolTarjeta -->|Procesar| TPV_Bank[TPV: Conexión Banco]
        DevolEfectivo -->|Cobrar| TPV_Caja[TPV: Apertura Cajón]
        
        TPV_Bank --> EmiteTickDev[Emisión de Ticket de devolución]
        TPV_Caja --> EmiteTickDev
    end

    subgraph Sistemas ["INVENTARIO"]
        direction TB
        CargaApp ==>|Reserva| InvReserva[(Stock Comprometido)]
        EmiteTick ==>|Baja Mercadería| InvFinal[(Stock Actualizado)]

        EmiteTickDev -->|Devolución| InvFinal

        %% Conexión de estados
        InvReserva -.->|Libera al vender| InvFinal
    end